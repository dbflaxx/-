        <!-- Footer -->
        <footer>
            <span>Campus Quest v1.0.0 • Pure HTML/CSS/JavaScript Static App</span>
            <span>Created for College Student Study Productivity Boost</span>
        </footer>

    </div>

    <!-- ==========================================
       9. Core JavaScript Logic
       ========================================== -->
    <script>
        // --- 1. Global State & DOM Reference ---
        let todos = [];
        let selectedTag = 'major';
        let isCompletedCollapsed = false; // 완료 목록 접기 플래그

        // DOM elements
        const todoInput = document.getElementById('todo-input');
        const addBtn = document.getElementById('add-btn');
        const activeTodoList = document.getElementById('active-todo-list');
        const completedTodoList = document.getElementById('completed-todo-list');
        const scoreDisplay = document.getElementById('score-display');
        const remainingCountDisplay = document.getElementById('remaining-count-display');
        const completedCountDisplay = document.getElementById('completed-count-display');
        const levelBadge = document.getElementById('level-badge');
        const levelName = document.getElementById('level-name');
        const expDisplay = document.getElementById('exp-display');
        const levelProgressBar = document.getElementById('level-progress-bar');
        const todayRateBar = document.getElementById('today-rate-bar');
        const todayRatePercent = document.getElementById('today-rate-percent');
        const activeListCount = document.getElementById('active-list-count');
        const completedListCount = document.getElementById('completed-list-count');
        const toggleCollapseBtn = document.getElementById('toggle-collapse-btn');

        // Confetti Canvas setup
        const canvas = document.getElementById('confetti-canvas');
        const ctx = canvas.getContext('2d');
        let particles = [];

        // Resize Canvas dynamically
        function resizeCanvas() {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
        }
        window.addEventListener('resize', resizeCanvas);
        resizeCanvas();

        // Level Rules Configuration
        const LEVELS = [
            { level: 1, name: '학사 새내기', minScore: 0 },
            { level: 2, name: '학점 탐험가', minScore: 5 },
            { level: 3, name: '도서관 지키미', minScore: 10 },
            { level: 4, name: '전공 마스터', minScore: 15 },
            { level: 5, name: '학문의 신', minScore: 20 }
        ];

        // --- 2. LocalStorage Persistence ---
        function loadTodos() {
            const data = localStorage.getItem('campus_quest_todos');
            if (data) {
                try {
                    todos = JSON.parse(data);
                } catch (e) {
                    todos = [];
                }
            } else {
                todos = [];
            }
            
            const collapseState = localStorage.getItem('completed_collapsed');
            if (collapseState !== null) {
                isCompletedCollapsed = JSON.parse(collapseState);
            }
        }

        // --- Core Helper to save changes ---
        function saveTodos() {
            localStorage.setItem('campus_quest_todos', JSON.stringify(todos));
            localStorage.setItem('completed_collapsed', JSON.stringify(isCompletedCollapsed));
        }

        // --- 3. Level & Gamification Logic ---
        function updateDashboard() {
            // 1. 계산할 스탯들
            const score = todos.filter(t => t.step === 3).length; // 완료된 개수 = 점수
            const completedCount = score;
            const remainingCount = todos.filter(t => t.step < 3).length;
            const totalCount = todos.length;

            // 2. 스코어 및 퀘스트 개수 표시 갱신
            scoreDisplay.textContent = score;
            remainingCountDisplay.textContent = remainingCount;
            completedCountDisplay.textContent = completedCount;
            activeListCount.textContent = remainingCount;
            completedListCount.textContent = completedCount;

            // 3. 레벨 계산 (5점마다 레벨업)
            const level = Math.floor(score / 5) + 1;
            const currentExp = score % 5;
            const maxExp = 5;

            // 레벨 별 칭호 가져오기
            let levelTitle = '학사 새내기';
            for (let i = LEVELS.length - 1; i >= 0; i--) {
                if (score >= LEVELS[i].minScore) {
                    levelTitle = LEVELS[i].name;
                    break;
                }
            }

            // UI 갱신
            levelBadge.textContent = `LV.${level}`;
            levelName.textContent = levelTitle;
            expDisplay.textContent = `${currentExp} / ${maxExp} EXP`;
            
            // 레벨 진행도 채우기
            const levelPercent = (currentExp / maxExp) * 100;
            levelProgressBar.style.width = `${levelPercent}%`;

            // 4. 학업 완료율(달성도) 진행바 계산
            const ratePercent = totalCount > 0 ? Math.round((completedCount / totalCount) * 100) : 0;
            todayRateBar.style.width = `${ratePercent}%`;
            todayRatePercent.textContent = `${ratePercent}%`;

            // 완료 목록 접힘/펼침 버튼 텍스트 동기화
            if (isCompletedCollapsed) {
                completedTodoList.classList.add('collapsed');
                toggleCollapseBtn.classList.add('collapsed');
                toggleCollapseBtn.innerHTML = `
                    <svg viewBox="0 0 24 24">
                        <path d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6 1.41-1.41z"/>
                    </svg> 펼치기
                `;
            } else {
                completedTodoList.classList.remove('collapsed');
                toggleCollapseBtn.classList.remove('collapsed');
                toggleCollapseBtn.innerHTML = `
                    <svg viewBox="0 0 24 24">
                        <path d="M12 8l-6 6 1.41 1.41L12 10.83l4.59 4.58L18 14z"/>
                    </svg> 접기
                `;
            }
        }

        // --- 4. Confetti Spark Effect Engine ---
        class ConfettiParticle {
            constructor(x, y) {
                this.x = x;
                this.y = y;
                this.size = Math.random() * 6 + 4;
                this.speedX = Math.random() * 8 - 4;
                this.speedY = Math.random() * -10 - 5; // upward burst
                this.color = `hsl(${Math.random() * 360}, 90%, 60%)`;
                this.gravity = 0.3;
                this.friction = 0.98;
                this.opacity = 1;
                this.fade = Math.random() * 0.015 + 0.01;
            }

            update() {
                this.speedX *= this.friction;
                this.speedY += this.gravity;
                this.x += this.speedX;
                this.y += this.speedY;
                this.opacity -= this.fade;
            }

            draw() {
                ctx.save();
                ctx.globalAlpha = this.opacity;
                ctx.fillStyle = this.color;
                ctx.beginPath();
                ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
                ctx.fill();
                ctx.restore();
            }
        }

        function triggerConfetti(e) {
            // Clicked element coords
            const rect = e.target.getBoundingClientRect();
            const clickX = rect.left + rect.width / 2;
            const clickY = rect.top + rect.height / 2;

            for (let i = 0; i < 40; i++) {
                particles.push(new ConfettiParticle(clickX, clickY));
            }
        }

        function animateParticles() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            particles.forEach((p, idx) => {
                p.update();
                p.draw();
                if (p.opacity <= 0) {
                    particles.splice(idx, 1);
                }
            });
            requestAnimationFrame(animateParticles);
        }
        animateParticles();

        // --- 5. Step Progression & Todo Operations ---
        
        // Add Todo
        function addTodo() {
            const text = todoInput.value.trim();
            if (!text) return;

            const newTodo = {
                id: Date.now().toString(),
                text: text,
                tag: selectedTag,
                step: 0, // 0: 미체크, 1: 계획, 2: 실행, 3: 완료
                createdAt: Date.now()
            };

            todos.push(newTodo);
            todoInput.value = '';
            
            saveTodos();
            renderTodos();
            updateDashboard();
        }

        // Delete Todo
        function deleteTodo(id) {
            const card = document.getElementById(`todo-${id}`);
            if (card) {
                card.classList.add('removing');
                // Wait for animation to finish
                card.addEventListener('animationend', () => {
                    todos = todos.filter(t => t.id !== id);
                    saveTodos();
                    renderTodos();
                    updateDashboard();
                });
            }
        }

        // Change Todo Step Sequence (계획 -> 실행 -> 완료)
        function changeStep(todoId, targetStep, event) {
            const todo = todos.find(t => t.id === todoId);
            if (!todo) return;

            // 1단계(계획) 토글 및 제약 조건
            if (targetStep === 1) {
                if (todo.step === 0) {
                    todo.step = 1;
                } else if (todo.step === 1) {
                    todo.step = 0;
                } else {
                    // 이미 실행/완료인 경우 계획 클릭하면 0으로 초기화
                    todo.step = 0;
                }
            } 
            // 2단계(실행) 토글 및 제약 조건
            else if (targetStep === 2) {
                // 이전 단계인 '계획'이 활성화되어 있어야만 조작 가능
                if (todo.step < 1) return;
                
                if (todo.step === 1) {
                    todo.step = 2;
                } else if (todo.step === 2) {
                    todo.step = 1;
                } else if (todo.step === 3) {
                    // 완료 상태에서 클릭하면 실행 상태(2단계가 아니라 이전 단계인 1단계 계획 상태로 복귀하거나 실행 상태로 복귀)
                    todo.step = 1;
                }
            } 
            // 3단계(완료) 토글 및 제약 조건
            else if (targetStep === 3) {
                // 이전 단계인 '실행'이 활성화되어 있어야만 조작 가능
                if (todo.step < 2) return;
                
                if (todo.step === 2) {
                    todo.step = 3;
                    // 완료되는 시점에만 폭죽 효과 발동
                    triggerConfetti(event);
                } else if (todo.step === 3) {
                    todo.step = 2;
                }
            }

            saveTodos();
            renderTodos();
            updateDashboard();
        }

        // Formatted Date
        function formatDate(timestamp) {
            const d = new Date(timestamp);
            return `${d.getMonth() + 1}/${d.getDate()} ${String(d.getHours()).padStart(2, '0')}:${String(d.getMinutes()).padStart(2, '0')}`;
        }

        // Render Lists
        function renderTodos() {
            activeTodoList.innerHTML = '';
            completedTodoList.innerHTML = '';

            let activeCount = 0;
            let completedCount = 0;

            // Sort newest first
            const sortedTodos = [...todos].sort((a, b) => b.createdAt - a.createdAt);

            sortedTodos.forEach(todo => {
                const isCompleted = todo.step === 3;
                
                const card = document.createElement('div');
                card.id = `todo-${todo.id}`;
                card.className = `glass-panel task-card step-${todo.step} ${isCompleted ? 'completed' : ''}`;

                // Calculate progress line fill percentage
                let fillPercent = 0;
                if (todo.step === 1) fillPercent = 0; // line between plan and execute starts
                if (todo.step === 2) fillPercent = 50; // filled up to execute
                if (todo.step === 3) fillPercent = 100; // filled up to complete

                // Lock States for Step Buttons
                const isExecLocked = todo.step < 1;
                const isDoneLocked = todo.step < 2;

                card.innerHTML = `
                    <div class="card-header">
                        <div class="task-title-group">
                            <div class="task-meta">
                                <span class="category-badge" data-tag="${todo.tag}">${getTagKorean(todo.tag)}</span>
                                <span class="task-date">${formatDate(todo.createdAt)}</span>
                            </div>
                            <span class="task-text">${escapeHtml(todo.text)}</span>
                        </div>
                        <button class="delete-btn" onclick="deleteTodo('${todo.id}')" title="퀘스트 삭제">
                            <svg viewBox="0 0 24 24">
                                <path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/>
                            </svg>
                        </button>
                    </div>

                    <!-- RPG Quest-like Step Bar -->
                    <div class="quest-progress-section">
                        <div class="quest-progress-line-bg"></div>
                        <div class="quest-progress-line-fill" style="width: ${fillPercent}%;"></div>
                        
                        <div class="quest-steps">
                            <!-- Step 1: 계획 -->
                            <div class="quest-step-item">
                                <div class="step-circle plan" onclick="changeStep('${todo.id}', 1, event)">
                                    <svg viewBox="0 0 24 24">
                                        <path d="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z"/>
                                    </svg>
                                </div>
                                <span class="step-label plan">계획</span>
                            </div>

                            <!-- Step 2: 실행 -->
                            <div class="quest-step-item">
                                <div class="step-circle execute ${isExecLocked ? 'locked' : ''}" onclick="${isExecLocked ? '' : `changeStep('${todo.id}', 2, event)`}">
                                    <svg viewBox="0 0 24 24">
                                        <path d="M8 5v14l11-7z"/>
                                    </svg>
                                </div>
                                <span class="step-label execute">실행</span>
                            </div>

                            <!-- Step 3: 완료 -->
                            <div class="quest-step-item">
                                <div class="step-circle complete ${isDoneLocked ? 'locked' : ''}" onclick="${isDoneLocked ? '' : `changeStep('${todo.id}', 3, event)`}">
                                    <svg viewBox="0 0 24 24">
                                        <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
                                    </svg>
                                </div>
                                <span class="step-label complete">완료</span>
                            </div>
                        </div>
                    </div>
                `;

                if (isCompleted) {
                    completedTodoList.appendChild(card);
                    completedCount++;
                } else {
                    activeTodoList.appendChild(card);
                    activeCount++;
                }
            });

            // Empty State Handling
            if (activeCount === 0) {
                activeTodoList.innerHTML = `
                    <div class="empty-placeholder">
                        <svg viewBox="0 0 24 24">
                            <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V5h14v14zM17.99 9l-1.41-1.42-6.59 6.59-3.59-3.59-1.41 1.41 5 5z"/>
                        </svg>
                        <p>진행 중인 퀘스트가 없습니다. 새로운 퀘스트를 추가해 학업을 완수해 보세요!</p>
                    </div>
                `;
            }

            if (completedCount === 0) {
                completedTodoList.innerHTML = `
                    <div class="empty-placeholder">
                        <svg viewBox="0 0 24 24">
                            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/>
                        </svg>
                        <p>아직 완료된 퀘스트가 없습니다. 실행 단계를 거쳐 퀘스트를 완수하세요!</p>
                    </div>
                `;
            }
        }

        // Tag Helpers
        function getTagKorean(tag) {
            const tags = {
                major: '전공',
                general: '교양',
                assignment: '과제',
                exam: '시험',
                other: '기타'
            };
            return tags[tag] || '기타';
        }

        // Escape HTML to prevent XSS
        function escapeHtml(text) {
            const map = {
                '&': '&amp;',
                '<': '&lt;',
                '>': '&gt;',
                '"': '&quot;',
                "'": '&#039;'
            };
            return text.replace(/[&<>"']/g, function(m) { return map[m]; });
        }

        // --- 6. Event Listeners ---
        
        // Tag selection logic
        document.querySelectorAll('.tag-option').forEach(option => {
            option.addEventListener('click', () => {
                document.querySelectorAll('.tag-option').forEach(o => o.classList.remove('selected'));
                option.classList.add('selected');
                selectedTag = option.dataset.tag;
            });
        });

        // Add Button and Enter Key logic
        addBtn.addEventListener('click', addTodo);
        todoInput.addEventListener('keydown', (e) => {
            if (e.key === 'Enter') {
                addTodo();
            }
        });

        // Collapse/Expand completed items
        toggleCollapseBtn.addEventListener('click', () => {
            isCompletedCollapsed = !isCompletedCollapsed;
            saveTodos();
            updateDashboard();
        });

        // --- 7. App Initialization ---
        function init() {
            loadTodos();
            renderTodos();
            updateDashboard();
        }

        init();
    </script>
</body>
</html>
