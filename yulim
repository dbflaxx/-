<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Campus Quest - 대학생 학습 계획 관리 플래너</title>
    <!-- Google Fonts: Outfit & Inter for premium typography -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700;800&family=Noto+Sans+KR:wght@300;400;500;700&display=swap" rel="stylesheet">
    
    <style>
        /* ==========================================
           1. CSS Reset & Variables (디자인 시스템)
           ========================================== */
        :root {
            --bg-color: #080b11;
            --bg-gradient: radial-gradient(circle at 50% 0%, #151e33 0%, #080b11 70%);
            --card-bg: rgba(17, 24, 39, 0.65);
            --card-hover-bg: rgba(23, 33, 53, 0.8);
            --card-border: rgba(255, 255, 255, 0.06);
            --card-border-active: rgba(59, 130, 246, 0.4);
            --card-border-success: rgba(16, 185, 129, 0.4);
            
            --text-main: #f3f4f6;
            --text-sub: #9ca3af;
            --text-muted: #6b7280;
            
            /* Point Colors */
            --primary: #3b82f6;          /* Neon Blue */
            --primary-hover: #2563eb;
            --primary-glow: rgba(59, 130, 246, 0.35);
            --secondary: #06b6d4;        /* Cyan */
            --success: #10b981;          /* Emerald Green */
            --success-glow: rgba(16, 185, 129, 0.3);
            --warning: #f59e0b;          /* Amber */
            --danger: #ef4444;           /* Coral Red */
            
            /* Tag Colors */
            --tag-major: #f87171;        /* 전공 */
            --tag-general: #60a5fa;      /* 교양 */
            --tag-assignment: #c084fc;   /* 과제 */
            --tag-exam: #fbbf24;         /* 시험 */
            --tag-other: #9ca3af;        /* 기타 */
            
            --transition-smooth: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Outfit', 'Inter', 'Noto Sans KR', sans-serif;
            background-color: var(--bg-color);
            background-image: var(--bg-gradient);
            color: var(--text-main);
            min-height: 100vh;
            line-height: 1.5;
            padding: 2rem 1rem;
            display: flex;
            justify-content: center;
            overflow-x: hidden;
        }

        /* Confetti Canvas */
        #confetti-canvas {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 9999;
        }

        /* Container Layout */
        .app-container {
            width: 100%;
            max-width: 800px;
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        }

        /* Glassmorphism Common Style */
        .glass-panel {
            background: var(--card-bg);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid var(--card-border);
            border-radius: 1.25rem;
            padding: 1.5rem;
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.3);
            transition: var(--transition-smooth);
        }

        /* ==========================================
           2. Header & Profile (레벨 및 진행바 영역)
           ========================================== */
        header.dashboard {
            display: flex;
            flex-direction: column;
            gap: 1.25rem;
            position: relative;
        }

        .header-top {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .app-title-area {
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .app-logo {
            width: 2.75rem;
            height: 2.75rem;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            border-radius: 0.75rem;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 0 15px var(--primary-glow);
        }

        .app-logo svg {
            width: 1.5rem;
            height: 1.5rem;
            fill: #fff;
        }

        .app-title {
            font-size: 1.5rem;
            font-weight: 800;
            letter-spacing: -0.025em;
            background: linear-gradient(to right, #ffffff, #93c5fd);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        /* Stats Grid */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1rem;
        }

        .stat-card {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.04);
            border-radius: 0.75rem;
            padding: 0.75rem 1rem;
            text-align: center;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .stat-label {
            font-size: 0.75rem;
            color: var(--text-sub);
            font-weight: 500;
            margin-bottom: 0.25rem;
        }

        .stat-value {
            font-size: 1.5rem;
            font-weight: 800;
            color: #fff;
            font-family: 'Outfit', sans-serif;
        }

        .stat-value.score {
            color: var(--secondary);
            text-shadow: 0 0 10px rgba(6, 182, 212, 0.3);
        }

        /* Level Progress Area */
        .level-section {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
            background: rgba(255, 255, 255, 0.02);
            border-radius: 0.85rem;
            padding: 1rem;
            border: 1px solid rgba(255, 255, 255, 0.03);
        }

        .level-info {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .level-badge-container {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .level-badge {
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            color: white;
            font-size: 0.75rem;
            font-weight: 700;
            padding: 0.25rem 0.6rem;
            border-radius: 100px;
            font-family: 'Outfit', sans-serif;
        }

        .level-name {
            font-weight: 600;
            font-size: 0.95rem;
            color: var(--text-main);
        }

        .level-exp {
            font-size: 0.75rem;
            color: var(--text-sub);
            font-family: 'Outfit', sans-serif;
        }

        /* Progress Bar Styles */
        .progress-bar-container {
            width: 100%;
            height: 0.5rem;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 100px;
            overflow: hidden;
            position: relative;
        }

        .progress-bar-fill {
            height: 100%;
            background: linear-gradient(to right, var(--primary), var(--secondary));
            width: 0%;
            border-radius: 100px;
            transition: width 0.5s ease-out;
        }

        /* Today's Rate Bar */
        .today-rate-section {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            padding: 0.5rem 0.25rem;
        }

        .today-rate-text {
            font-size: 0.8rem;
            color: var(--text-sub);
            display: flex;
            align-items: center;
            gap: 0.35rem;
            white-space: nowrap;
        }

        .today-rate-text svg {
            width: 0.9rem;
            height: 0.9rem;
            fill: var(--primary);
        }

        .today-rate-bar-wrapper {
            flex-grow: 1;
            height: 0.35rem;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 100px;
            overflow: hidden;
        }

        .today-rate-bar-fill {
            height: 100%;
            background: linear-gradient(to right, var(--secondary), var(--success));
            width: 0%;
            border-radius: 100px;
            transition: width 0.5s ease-out;
        }

        .today-rate-percent {
            font-size: 0.8rem;
            font-weight: 700;
            color: var(--success);
            font-family: 'Outfit', sans-serif;
            min-width: 2.2rem;
            text-align: right;
        }

        /* ==========================================
           3. Todo Input Form (퀘스트 등록 영역)
           ========================================== */
        .input-form {
            display: flex;
            flex-direction: column;
            gap: 0.85rem;
        }

        .input-row {
            display: flex;
            gap: 0.75rem;
        }

        .input-field-wrapper {
            position: relative;
            flex-grow: 1;
        }

        .input-field-wrapper svg {
            position: absolute;
            left: 1rem;
            top: 50%;
            transform: translateY(-50%);
            width: 1.15rem;
            height: 1.15rem;
            fill: var(--text-muted);
            pointer-events: none;
            transition: var(--transition-smooth);
        }

        .text-input {
            width: 100%;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid var(--card-border);
            border-radius: 0.85rem;
            padding: 0.85rem 1rem 0.85rem 2.75rem;
            color: #fff;
            font-size: 0.95rem;
            font-family: 'Noto Sans KR', sans-serif;
            transition: var(--transition-smooth);
        }

        .text-input:focus {
            outline: none;
            border-color: var(--primary);
            background: rgba(255, 255, 255, 0.06);
            box-shadow: 0 0 12px var(--primary-glow);
        }

        .text-input:focus + svg {
            fill: var(--primary);
        }

        /* Tag Selector */
        .tag-selector {
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
        }

        .tag-option {
            cursor: pointer;
            padding: 0.4rem 0.85rem;
            border-radius: 100px;
            font-size: 0.75rem;
            font-weight: 600;
            border: 1px solid rgba(255, 255, 255, 0.05);
            background: rgba(255, 255, 255, 0.02);
            color: var(--text-sub);
            transition: var(--transition-smooth);
            display: flex;
            align-items: center;
            gap: 0.35rem;
            user-select: none;
        }

        .tag-dot {
            width: 0.5rem;
            height: 0.5rem;
            border-radius: 50%;
        }

        .tag-option[data-tag="major"] .tag-dot { background-color: var(--tag-major); }
        .tag-option[data-tag="general"] .tag-dot { background-color: var(--tag-general); }
        .tag-option[data-tag="assignment"] .tag-dot { background-color: var(--tag-assignment); }
        .tag-option[data-tag="exam"] .tag-dot { background-color: var(--tag-exam); }
        .tag-option[data-tag="other"] .tag-dot { background-color: var(--tag-other); }

        .tag-option:hover {
            background: rgba(255, 255, 255, 0.06);
            color: #fff;
            border-color: rgba(255, 255, 255, 0.15);
        }

        /* Tag selection states */
        .tag-option.selected[data-tag="major"] { background: rgba(248, 113, 113, 0.15); border-color: var(--tag-major); color: #fff; }
        .tag-option.selected[data-tag="general"] { background: rgba(96, 165, 250, 0.15); border-color: var(--tag-general); color: #fff; }
        .tag-option.selected[data-tag="assignment"] { background: rgba(192, 132, 252, 0.15); border-color: var(--tag-assignment); color: #fff; }
        .tag-option.selected[data-tag="exam"] { background: rgba(251, 191, 36, 0.15); border-color: var(--tag-exam); color: #fff; }
        .tag-option.selected[data-tag="other"] { background: rgba(156, 163, 175, 0.15); border-color: var(--tag-other); color: #fff; }

        .add-btn {
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            border: none;
            border-radius: 0.85rem;
            color: #fff;
            font-weight: 700;
            padding: 0 1.5rem;
            cursor: pointer;
            transition: var(--transition-smooth);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.4rem;
            box-shadow: 0 4px 15px rgba(59, 130, 246, 0.25);
            font-size: 0.9rem;
            white-space: nowrap;
        }

        .add-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(59, 130, 246, 0.4);
        }

        .add-btn:active {
            transform: translateY(0);
        }

        .add-btn svg {
            width: 1.1rem;
            height: 1.1rem;
            fill: #fff;
        }

        /* ==========================================
           4. Section Header & Fold Button
           ========================================== */
        .list-section-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 0.5rem;
            margin-bottom: 0.5rem;
        }

        .list-title {
            font-size: 1rem;
            font-weight: 700;
            color: #fff;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .list-title svg {
            width: 1.1rem;
            height: 1.1rem;
            fill: var(--primary);
        }

        .list-count-badge {
            background: rgba(255, 255, 255, 0.05);
            color: var(--text-sub);
            font-size: 0.75rem;
            font-weight: 600;
            padding: 0.15rem 0.5rem;
            border-radius: 100px;
            font-family: 'Outfit', sans-serif;
        }

        /* Collapse Toggle Button */
        .collapse-btn {
            background: transparent;
            border: 1px solid var(--card-border);
            border-radius: 0.5rem;
            color: var(--text-sub);
            padding: 0.3rem 0.75rem;
            font-size: 0.75rem;
            font-weight: 600;
            cursor: pointer;
            transition: var(--transition-smooth);
            display: flex;
            align-items: center;
            gap: 0.35rem;
        }

        .collapse-btn:hover {
            color: #fff;
            background: rgba(255, 255, 255, 0.05);
            border-color: rgba(255, 255, 255, 0.15);
        }

        .collapse-btn svg {
            width: 0.75rem;
            height: 0.75rem;
            fill: currentColor;
            transition: transform 0.3s ease;
        }

        .collapse-btn.collapsed svg {
            transform: rotate(-180deg);
        }

        /* ==========================================
           5. Todo Item Lists (할 일 리스트 영역)
           ========================================== */
        .todo-list-wrapper {
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
            transition: var(--transition-smooth);
        }

        .todo-list-wrapper.collapsed {
            display: none;
        }

        /* Empty State Placeholder */
        .empty-placeholder {
            text-align: center;
            padding: 2.5rem 1.5rem;
            border: 1px dashed var(--card-border);
            border-radius: 1rem;
            color: var(--text-muted);
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.75rem;
        }

        .empty-placeholder svg {
            width: 2.5rem;
            height: 2.5rem;
            fill: var(--text-muted);
            opacity: 0.5;
        }

        .empty-placeholder p {
            font-size: 0.85rem;
            max-width: 250px;
            word-break: keep-all;
        }

        /* ==========================================
           6. Task Card UI (할 일 카드)
           ========================================== */
        .task-card {
            display: flex;
            flex-direction: column;
            gap: 1rem;
            animation: fadeIn 0.35s cubic-bezier(0.4, 0, 0.2, 1) forwards;
        }

        .task-card:hover {
            background-color: var(--card-hover-bg);
            border-color: var(--card-border-active);
        }

        /* Completed Task Card Styling */
        .task-card.completed {
            border-color: var(--card-border-success);
            background: rgba(16, 185, 129, 0.02);
        }

        .task-card.completed:hover {
            background: rgba(16, 185, 129, 0.04);
        }

        /* Card Header */
        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 1rem;
        }

        .task-title-group {
            display: flex;
            flex-direction: column;
            gap: 0.4rem;
            flex-grow: 1;
        }

        .task-meta {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        /* Category Badges */
        .category-badge {
            font-size: 0.65rem;
            font-weight: 700;
            padding: 0.15rem 0.5rem;
            border-radius: 100px;
            text-transform: uppercase;
        }

        .category-badge[data-tag="major"] { background: rgba(248, 113, 113, 0.12); color: var(--tag-major); }
        .category-badge[data-tag="general"] { background: rgba(96, 165, 250, 0.12); color: var(--tag-general); }
        .category-badge[data-tag="assignment"] { background: rgba(192, 132, 252, 0.12); color: var(--tag-assignment); }
        .category-badge[data-tag="exam"] { background: rgba(251, 191, 36, 0.12); color: var(--tag-exam); }
        .category-badge[data-tag="other"] { background: rgba(156, 163, 175, 0.12); color: var(--tag-other); }

        .task-date {
            font-size: 0.7rem;
            color: var(--text-muted);
            font-family: 'Outfit', sans-serif;
        }

        .task-text {
            font-size: 0.95rem;
            font-weight: 500;
            color: var(--text-main);
            word-break: break-all;
            transition: var(--transition-smooth);
        }

        .task-card.completed .task-text {
            color: var(--text-muted);
            text-decoration: line-through;
        }

        /* Delete Button */
        .delete-btn {
            background: transparent;
            border: none;
            cursor: pointer;
            padding: 0.25rem;
            border-radius: 0.35rem;
            color: var(--text-muted);
            transition: var(--transition-smooth);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .delete-btn:hover {
            color: var(--danger);
            background: rgba(239, 68, 68, 0.08);
        }

        .delete-btn svg {
            width: 1.15rem;
            height: 1.15rem;
            fill: currentColor;
        }

        /* 3-Step Progression UI */
        .quest-progress-section {
            display: flex;
            align-items: center;
            position: relative;
            padding: 0.25rem 0.5rem;
            background: rgba(0, 0, 0, 0.15);
            border-radius: 0.75rem;
            margin-top: 0.25rem;
        }

        /* Step Progress Line Connector */
        .quest-progress-line-bg {
            position: absolute;
            top: 50%;
            left: calc(16.66% + 12px);
            right: calc(16.66% + 12px);
            height: 3px;
            background: rgba(255, 255, 255, 0.06);
            transform: translateY(-50%);
            z-index: 1;
        }

        .quest-progress-line-fill {
            position: absolute;
            top: 50%;
            left: calc(16.66% + 12px);
            height: 3px;
            background: linear-gradient(to right, var(--primary), var(--secondary), var(--success));
            transform: translateY(-50%);
            z-index: 2;
            transition: width 0.35s cubic-bezier(0.4, 0, 0.2, 1);
            width: 0%; /* Dynamic width based on step: 0% / 50% / 100% */
        }

        /* Step Buttons Grid */
        .quest-steps {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            width: 100%;
            position: relative;
            z-index: 3;
        }

        .quest-step-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.35rem;
        }

        .step-circle {
            width: 1.75rem;
            height: 1.75rem;
            border-radius: 50%;
            background: #111827;
            border: 2px solid rgba(255, 255, 255, 0.1);
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: var(--transition-smooth);
            position: relative;
        }

        .step-circle svg {
            width: 0.8rem;
            height: 0.8rem;
            fill: transparent;
            transition: var(--transition-smooth);
        }

        .step-label {
            font-size: 0.65rem;
            font-weight: 700;
            color: var(--text-muted);
            transition: var(--transition-smooth);
            user-select: none;
        }

        /* Locked state */
        .step-circle.locked {
            cursor: not-allowed;
            opacity: 0.35;
        }

        /* Active / Checked States for each phase */
        
        /* 1. 계획 (Plan) Checked */
        .task-card.step-1 .step-circle.plan,
        .task-card.step-2 .step-circle.plan,
        .task-card.step-3 .step-circle.plan {
            background: rgba(59, 130, 246, 0.15);
            border-color: var(--primary);
            box-shadow: 0 0 8px var(--primary-glow);
        }
        .task-card.step-1 .step-circle.plan svg,
        .task-card.step-2 .step-circle.plan svg,
        .task-card.step-3 .step-circle.plan svg {
            fill: var(--primary);
        }
        .task-card.step-1 .step-label.plan,
        .task-card.step-2 .step-label.plan,
        .task-card.step-3 .step-label.plan {
            color: var(--primary);
        }

        /* 2. 실행 (Execute) Checked */
        .task-card.step-2 .step-circle.execute,
        .task-card.step-3 .step-circle.execute {
            background: rgba(6, 182, 212, 0.15);
            border-color: var(--secondary);
            box-shadow: 0 0 8px rgba(6, 182, 212, 0.3);
        }
        .task-card.step-2 .step-circle.execute svg,
        .task-card.step-3 .step-circle.execute svg {
            fill: var(--secondary);
        }
        .task-card.step-2 .step-label.execute,
        .task-card.step-3 .step-label.execute {
            color: var(--secondary);
        }

        /* 3. 완료 (Complete) Checked */
        .task-card.step-3 .step-circle.complete {
            background: rgba(16, 185, 129, 0.15);
            border-color: var(--success);
            box-shadow: 0 0 10px var(--success-glow);
        }
        .task-card.step-3 .step-circle.complete svg {
            fill: var(--success);
        }
        .task-card.step-3 .step-label.complete {
            color: var(--success);
        }

        /* Card removing animation class */
        .task-card.removing {
            animation: fadeOut 0.3s cubic-bezier(0.4, 0, 0.2, 1) forwards;
        }

        /* ==========================================
           7. Footer (푸터)
           ========================================== */
        footer {
            margin-top: 1.5rem;
            text-align: center;
            color: var(--text-muted);
            font-size: 0.75rem;
            display: flex;
            flex-direction: column;
            gap: 0.25rem;
        }

        footer a {
            color: var(--primary);
            text-decoration: none;
            transition: var(--transition-smooth);
        }

        footer a:hover {
            color: var(--secondary);
            text-decoration: underline;
        }

        /* ==========================================
           8. Responsive Design (반응형 지원)
           ========================================== */
        @media (max-width: 600px) {
            body {
                padding: 1rem 0.5rem;
            }
            .glass-panel {
                padding: 1.15rem;
                border-radius: 1rem;
            }
            .app-logo {
                width: 2.25rem;
                height: 2.25rem;
                border-radius: 0.6rem;
            }
            .app-logo svg {
                width: 1.2rem;
                height: 1.2rem;
