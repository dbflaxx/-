<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="대학생을 위한 고품격 학습 계획 및 실행 관리 투두리스트. 계획에서 완료까지 단계별 성장을 경험해보세요.">
  <title>CAMPUS GROW - 대학생 학습 계획 관리 투두리스트</title>
  
  <!-- Google Fonts for Modern Typography -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Noto+Sans+KR:wght@300;400;500;700;900&display=swap" rel="stylesheet">

  <style>
    /* ==========================================
       1. DESIGN SYSTEM & ROOT VARIABLES
       ========================================== */
    :root {
      --bg-gradient: radial-gradient(circle at 50% 0%, #0d1527 0%, #070a13 100%);
      --panel-bg: rgba(19, 26, 42, 0.75);
      --card-bg: rgba(30, 41, 59, 0.45);
      --card-hover-bg: rgba(30, 41, 59, 0.65);
      --border-color: rgba(255, 255, 255, 0.08);
      --border-focus: rgba(59, 130, 246, 0.6);
      
      --color-primary: #3b82f6; /* Classic Blue */
      --color-primary-glow: rgba(59, 130, 246, 0.35);
      --color-accent: #60a5fa; /* Light Blue */
      --color-success: #10b981; /* Emerald green */
      --color-success-glow: rgba(16, 185, 129, 0.25);
      --color-warning: #f59e0b; /* Amber */
      --color-danger: #ef4444; /* Rose Red */
      --color-danger-glow: rgba(239, 68, 68, 0.2);
      
      --text-main: #f8fafc;
      --text-muted: #94a3b8;
      --text-dark: #64748b;
      
      --font-display: 'Plus Jakarta Sans', 'Outfit', 'Noto Sans KR', sans-serif;
      --font-body: 'Inter', 'Noto Sans KR', sans-serif;
      
      --glow-box: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
      --glow-blue: 0 0 20px rgba(59, 130, 246, 0.15);
      --glow-success: 0 0 20px rgba(16, 185, 129, 0.15);
      
      --transition-smooth: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      --transition-bounce: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    /* ==========================================
       2. RESET & BASE STYLES
       ========================================== */
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
      user-select: none;
    }

    body {
      background: var(--bg-gradient);
      color: var(--text-main);
      font-family: var(--font-body);
      min-height: 100vh;
      display: flex;
      justify-content: center;
      padding: 40px 20px;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
    }

    input, button {
      font-family: inherit;
      color: inherit;
      outline: none;
    }

    /* Scrollbar Style */
    ::-webkit-scrollbar {
      width: 8px;
    }
    ::-webkit-scrollbar-track {
      background: rgba(0, 0, 0, 0.1);
    }
    ::-webkit-scrollbar-thumb {
      background: rgba(255, 255, 255, 0.1);
      border-radius: 4px;
    }
    ::-webkit-scrollbar-thumb:hover {
      background: rgba(255, 255, 255, 0.2);
    }

    /* ==========================================
       3. LAYOUT CONTAINER
       ========================================== */
    .app-container {
      width: 100%;
      max-width: 680px;
      display: flex;
      flex-direction: column;
      gap: 24px;
      animation: fadeIn 0.6s ease-out;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(15px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* ==========================================
       4. GLASSMORPHIC HEADER / SCOREBOARD
       ========================================== */
    .header-panel {
      background: var(--panel-bg);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid var(--border-color);
      border-radius: 24px;
      padding: 24px;
      box-shadow: var(--glow-box), var(--glow-blue);
      position: relative;
      overflow: hidden;
    }

    /* Top Brand Indicator */
    .brand-section {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 20px;
    }

    .logo-container {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .logo-icon {
      background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
      width: 38px;
      height: 38px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 4px 12px rgba(59, 130, 246, 0.4);
    }

    .logo-icon svg {
      width: 22px;
      height: 22px;
      fill: white;
    }

    .brand-title {
      font-family: var(--font-display);
      font-size: 20px;
      font-weight: 800;
      letter-spacing: -0.5px;
      background: linear-gradient(to right, #ffffff, #93c5fd);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .badge-rank {
      font-family: var(--font-display);
      font-size: 11px;
      font-weight: 700;
      background: rgba(59, 130, 246, 0.15);
      border: 1.5px solid rgba(59, 130, 246, 0.35);
      color: #93c5fd;
      padding: 4px 10px;
      border-radius: 20px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      box-shadow: 0 0 10px rgba(59, 130, 246, 0.1);
      transition: var(--transition-smooth);
    }

    .badge-rank.rank-gold {
      background: rgba(245, 158, 11, 0.15);
      border-color: rgba(245, 158, 11, 0.5);
      color: #fbbf24;
      box-shadow: 0 0 10px rgba(245, 158, 11, 0.1);
    }

    .badge-rank.rank-silver {
      background: rgba(203, 213, 225, 0.15);
      border-color: rgba(203, 213, 225, 0.5);
      color: #e2e8f0;
      box-shadow: 0 0 10px rgba(203, 213, 225, 0.1);
    }

    /* Score and Stats Grid */
    .stats-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      margin-bottom: 20px;
    }

    .stat-card {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 16px;
      padding: 16px;
      display: flex;
      align-items: center;
      gap: 14px;
      transition: var(--transition-smooth);
    }

    .stat-card:hover {
      border-color: rgba(255, 255, 255, 0.12);
      transform: translateY(-2px);
    }

    .stat-icon {
      width: 44px;
      height: 44px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .stat-icon.score {
      background: rgba(59, 130, 246, 0.1);
      color: var(--color-primary);
    }

    .stat-icon.complete {
      background: rgba(16, 185, 129, 0.1);
      color: var(--color-success);
    }

    .stat-icon svg {
      width: 24px;
      height: 24px;
    }

    .stat-info {
      display: flex;
      flex-direction: column;
    }

    .stat-label {
      font-size: 12px;
      color: var(--text-muted);
      font-weight: 500;
    }

    .stat-val {
      font-family: var(--font-display);
      font-size: 24px;
      font-weight: 700;
      color: var(--text-main);
      display: flex;
      align-items: baseline;
      gap: 2px;
    }

    .stat-val-unit {
      font-size: 12px;
      color: var(--text-muted);
      font-weight: 500;
    }

    /* Progress Bar to next Rank */
    .progress-section {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .progress-meta {
      display: flex;
      justify-content: space-between;
      font-size: 11px;
      color: var(--text-muted);
      font-weight: 500;
    }

    .progress-bar-container {
      background: rgba(255, 255, 255, 0.05);
      border-radius: 10px;
      height: 8px;
      width: 100%;
      overflow: hidden;
      position: relative;
    }

    .progress-bar-fill {
      background: linear-gradient(to right, var(--color-primary), var(--color-accent));
      height: 100%;
      width: 0%;
      border-radius: 10px;
      transition: width 0.6s cubic-bezier(0.4, 0, 0.2, 1);
      box-shadow: 0 0 10px rgba(59, 130, 246, 0.5);
    }

    /* ==========================================
       5. TASK INPUT FORM
       ========================================== */
    .input-panel {
      background: var(--panel-bg);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid var(--border-color);
      border-radius: 20px;
      padding: 16px;
      box-shadow: var(--glow-box);
    }

    .input-form {
      display: flex;
      gap: 12px;
    }

    .input-wrapper {
      position: relative;
      flex: 1;
    }

    .input-field {
      width: 100%;
      background: rgba(0, 0, 0, 0.2);
      border: 1px solid var(--border-color);
      padding: 14px 16px 14px 44px;
      border-radius: 14px;
      font-size: 14px;
      color: var(--text-main);
      transition: var(--transition-smooth);
    }

    .input-field:focus {
      border-color: var(--color-primary);
      box-shadow: 0 0 14px rgba(59, 130, 246, 0.15);
      background: rgba(0, 0, 0, 0.3);
    }

    .input-field::placeholder {
      color: var(--text-dark);
    }

    .input-icon-left {
      position: absolute;
      left: 14px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--text-dark);
      pointer-events: none;
      transition: var(--transition-smooth);
    }

    .input-field:focus ~ .input-icon-left {
      color: var(--color-primary);
    }

    .btn-submit {
      background: linear-gradient(135deg, var(--color-primary), #2563eb);
      color: white;
      border: none;
      padding: 0 20px;
      border-radius: 14px;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 8px;
      transition: var(--transition-bounce);
      box-shadow: 0 4px 12px rgba(59, 130, 246, 0.25);
    }

    .btn-submit:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 16px rgba(59, 130, 246, 0.4);
      filter: brightness(1.15);
    }

    .btn-submit:active {
      transform: translateY(1px);
    }

    /* ==========================================
       6. FILTER TABS
       ========================================== */
    .filter-section {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .filter-tabs {
      display: flex;
      background: rgba(0, 0, 0, 0.25);
      padding: 4px;
      border-radius: 12px;
      border: 1px solid var(--border-color);
    }

    .filter-tab {
      background: transparent;
      border: none;
      padding: 8px 16px;
      border-radius: 8px;
      font-size: 13px;
      font-weight: 600;
      color: var(--text-muted);
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 6px;
      transition: var(--transition-smooth);
    }

    .filter-tab.active {
      background: rgba(255, 255, 255, 0.08);
      color: var(--text-main);
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
    }

    .tab-badge {
      background: rgba(255, 255, 255, 0.1);
      color: var(--text-muted);
      padding: 1px 6px;
      border-radius: 8px;
      font-size: 11px;
    }

    .filter-tab.active .tab-badge {
      background: var(--color-primary);
      color: white;
    }

    /* Reset button */
    .btn-clear-completed {
      background: transparent;
      border: none;
      font-size: 12px;
      color: var(--text-dark);
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 4px;
      transition: var(--transition-smooth);
    }

    .btn-clear-completed:hover {
      color: var(--color-danger);
    }

    /* ==========================================
       7. TASK CARD LISTINGS
       ========================================== */
    .task-list {
      display: flex;
      flex-direction: column;
      gap: 16px;
      min-height: 150px;
    }

    .task-card {
      background: var(--panel-bg);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid var(--border-color);
      border-radius: 20px;
      padding: 20px;
      display: flex;
      flex-direction: column;
      gap: 16px;
      position: relative;
      box-shadow: var(--glow-box);
      transition: var(--transition-bounce);
      animation: slideIn 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    @keyframes slideIn {
      from { opacity: 0; transform: translateY(12px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .task-card.removing {
      opacity: 0;
      transform: scale(0.9) translateY(-10px);
      transition: var(--transition-smooth);
    }

    .task-card:hover {
      border-color: rgba(59, 130, 246, 0.25);
      box-shadow: var(--glow-box), 0 0 18px rgba(59, 130, 246, 0.05);
    }

    /* Top row inside card */
    .task-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 12px;
    }

    .task-title-container {
      display: flex;
      align-items: center;
      gap: 10px;
      flex: 1;
    }

    .task-bullet {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--color-primary);
      flex-shrink: 0;
      box-shadow: 0 0 8px var(--color-primary);
    }

    .task-card.state-complete .task-bullet {
      background: var(--color-success);
      box-shadow: 0 0 8px var(--color-success);
    }

    .task-title {
      font-size: 15px;
      font-weight: 600;
      color: var(--text-main);
      line-height: 1.4;
      word-break: break-all;
      transition: var(--transition-smooth);
    }

    .task-card.state-complete .task-title {
      color: var(--text-muted);
      text-decoration: line-through;
      text-decoration-color: rgba(255, 255, 255, 0.2);
    }

    .btn-delete {
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid var(--border-color);
      width: 32px;
      height: 32px;
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      color: var(--text-dark);
      transition: var(--transition-smooth);
    }

    .btn-delete:hover {
      background: var(--color-danger-glow);
      border-color: rgba(239, 68, 68, 0.3);
      color: var(--color-danger);
      transform: scale(1.05);
    }

    /* 3-Step checklist container */
    .checklist-flow {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      background: rgba(0, 0, 0, 0.15);
      border: 1px solid rgba(255, 255, 255, 0.03);
      border-radius: 14px;
      padding: 4px;
      position: relative;
    }

    /* Checklist Step pill */
    .step-pill {
      background: transparent;
      border: none;
      padding: 10px 8px;
      border-radius: 10px;
      font-size: 12px;
      font-weight: 600;
      color: var(--text-dark);
      cursor: not-allowed;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      transition: var(--transition-smooth);
      position: relative;
    }

    /* Step states */
    /* 1. Locked state (default) */
    .step-pill.locked svg.lock-icon {
      display: block;
    }
    .step-pill.locked svg.check-icon {
      display: none;
    }

    /* 2. Unlocked (Active but unchecked) */
    .step-pill.unlocked {
      color: var(--text-muted);
      cursor: pointer;
    }
    .step-pill.unlocked:hover {
      background: rgba(255, 255, 255, 0.04);
      color: var(--text-main);
    }
    .step-pill.unlocked svg.lock-icon {
      display: none;
    }
    .step-pill.unlocked svg.check-icon {
      display: block;
      opacity: 0.3;
    }

    /* 3. Checked State */
    .step-pill.checked {
      cursor: pointer;
    }
    .step-pill.checked svg.lock-icon {
      display: none;
    }
    .step-pill.checked svg.check-icon {
      display: block;
      opacity: 1;
    }

    /* Individual step styles when checked */
    .step-pill[data-step="plan"].checked {
      background: rgba(59, 130, 246, 0.12);
      color: var(--color-accent);
      border: 1px solid rgba(59, 130, 246, 0.25);
    }
    
    .step-pill[data-step="execute"].checked {
      background: rgba(245, 158, 11, 0.1);
      color: var(--color-warning);
      border: 1px solid rgba(245, 158, 11, 0.25);
    }
    
    .step-pill[data-step="complete"].checked {
      background: rgba(16, 185, 129, 0.12);
      color: var(--color-success);
      border: 1px solid rgba(16, 185, 129, 0.3);
      box-shadow: var(--glow-success);
    }

    .step-pill svg {
      width: 14px;
      height: 14px;
      flex-shrink: 0;
    }

    /* Arrow connectives in CSS */
    .checklist-flow .step-connector {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      color: rgba(255, 255, 255, 0.1);
      pointer-events: none;
      font-size: 10px;
    }

    .checklist-flow .step-connector.c1 {
      left: 33.33%;
      transform: translate(-50%, -50%);
    }

    .checklist-flow .step-connector.c2 {
      left: 66.66%;
      transform: translate(-50%, -50%);
    }

    /* Empty state */
    .empty-state {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 48px 24px;
      background: var(--panel-bg);
      border: 1px dashed rgba(255, 255, 255, 0.08);
      border-radius: 20px;
      gap: 16px;
      animation: fadeIn 0.4s ease-out;
    }

    .empty-icon {
      background: rgba(59, 130, 246, 0.05);
      color: var(--text-dark);
      width: 64px;
      height: 64px;
      border-radius: 20px;
      display: flex;
      align-items: center;
      justify-content: center;
      border: 1px solid rgba(255, 255, 255, 0.03);
    }

    .empty-icon svg {
      width: 32px;
      height: 32px;
    }

    .empty-title {
      font-size: 16px;
      font-weight: 700;
      color: var(--text-main);
    }

    .empty-desc {
      font-size: 13px;
      color: var(--text-muted);
      max-width: 280px;
      line-height: 1.5;
    }

    /* ==========================================
       8. FLOATING FEEDBACK & PARTICLES
       ========================================== */
    .particle {
      position: absolute;
      pointer-events: none;
      border-radius: 50%;
      z-index: 100;
      animation: particleBlow 0.8s cubic-bezier(0.1, 0.8, 0.3, 1) forwards;
    }

    @keyframes particleBlow {
      0% {
        transform: translate(0, 0) scale(1);
        opacity: 1;
      }
      100% {
        transform: translate(var(--tx), var(--ty)) scale(0);
        opacity: 0;
      }
    }

    /* Toast system */
    .toast-container {
      position: fixed;
      bottom: 24px;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      flex-direction: column;
      gap: 8px;
      z-index: 1000;
      pointer-events: none;
    }

    .toast {
      background: rgba(15, 23, 42, 0.95);
      border: 1px solid rgba(59, 130, 246, 0.3);
      padding: 12px 20px;
      border-radius: 12px;
      box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.5), var(--glow-blue);
      color: var(--text-main);
      font-size: 13px;
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 10px;
      pointer-events: auto;
      animation: toastIn 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards,
                 toastOut 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275) 2.5s forwards;
    }

    @keyframes toastIn {
      from { transform: translateY(20px) scale(0.9); opacity: 0; }
      to { transform: translateY(0) scale(1); opacity: 1; }
    }

    @keyframes toastOut {
      from { transform: translateY(0) scale(1); opacity: 1; }
      to { transform: translateY(15px) scale(0.9); opacity: 0; }
    }

    /* ==========================================
       9. RESPONSIVE DESIGN (MEDIA QUERIES)
       ========================================== */
    @media (max-width: 520px) {
      body {
        padding: 20px 12px;
      }
      
      .header-panel {
        padding: 16px;
        border-radius: 20px;
      }

      .stats-grid {
        gap: 12px;
        margin-bottom: 16px;
      }

      .stat-card {
        padding: 12px;
        gap: 10px;
      }

      .stat-icon {
        width: 36px;
        height: 36px;
      }

      .stat-icon svg {
        width: 20px;
        height: 20px;
      }

      .stat-val {
        font-size: 20px;
      }

      .input-panel {
        padding: 12px;
      }

      .input-form {
        flex-direction: column;
        gap: 10px;
      }

      .btn-submit {
        justify-content: center;
        padding: 12px;
      }

      .filter-section {
        flex-direction: column;
        align-items: stretch;
        gap: 12px;
      }

      .filter-tabs {
        width: 100%;
      }

      .filter-tab {
        flex: 1;
        justify-content: center;
      }

      .btn-clear-completed {
        justify-content: flex-end;
      }

      .task-card {
        padding: 16px;
      }

      .step-pill {
        font-size: 11px;
        padding: 8px 4px;
      }
    }
  </style>
</head>
<body>

  <div class="app-container">
    
    <!-- 1. HEADER / SCOREBOARD PANEL -->
    <header class="header-panel">
      <div class="brand-section">
        <div class="logo-container">
          <div class="logo-icon">
            <!-- Graduation Cap SVG -->
            <svg viewBox="0 0 24 24">
              <path d="M12 3L1 9l11 6 9-4.91V17h2V9L12 3zM5.89 12.55L12 15.89l6.11-3.34c-.65 1.76-2.3 3.05-4.29 3.39-1.2.2-2.44.2-3.64 0-1.99-.34-3.64-1.63-4.29-3.39z"/>
