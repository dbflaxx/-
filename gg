    <!-- 4. TASKS DISPLAY CONTAINER -->
    <main class="task-list" id="task-list-container"></main>

  </div>

  <!-- Toast Notification Container -->
  <div class="toast-container" id="toast-container"></div>

  <!-- ==========================================
     10. JAVASCRIPT APP LOGIC
     ========================================== -->
  <script>
    // State storage keys
    const STORAGE_KEY_TASKS = 'campugrow_tasks_v1';
    const STORAGE_KEY_SCORE = 'campugrow_score_v1';

    // Application state
    let state = {
      tasks: [],
      score: 0,
      filter: 'all'
    };

    // DOM Elements
    const elements = {
      taskInput: document.getElementById('task-input'),
      inputForm: document.getElementById('input-form'),
      taskListContainer: document.getElementById('task-list-container'),
      scoreVal: document.getElementById('score-val'),
      completedVal: document.getElementById('completed-val'),
      badgeRank: document.getElementById('badge-rank'),
      rankProgressLabel: document.getElementById('rank-progress-label'),
      rankProgressPercent: document.getElementById('rank-progress-percent'),
      progressBarFill: document.getElementById('progress-bar-fill'),
      tabAll: document.getElementById('tab-all'),
      tabActive: document.getElementById('tab-active'),
      tabCompleted: document.getElementById('tab-completed'),
      badgeAll: document.getElementById('badge-all'),
      badgeActive: document.getElementById('badge-active'),
      badgeCompleted: document.getElementById('badge-completed'),
      btnClearCompleted: document.getElementById('btn-clear-completed'),
      toastContainer: document.getElementById('toast-container')
    };

    // SVGs Definition for dynamic template insertion
    const SVGS = {
      lock: `<svg class="lock-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>`,
      check: `<svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>`,
      delete: `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>`,
      empty: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>`
    };

    // Rank Configurations (Gamification thresholds)
    const RANKS = [
      { name: 'BRONZE LEARNER', minScore: 0, maxScore: 10, colorClass: 'rank-bronze' },
      { name: 'SILVER ACHIEVER', minScore: 10, maxScore: 30, colorClass: 'rank-silver' },
      { name: 'GOLD MASTER', minScore: 30, maxScore: Infinity, colorClass: 'rank-gold' }
    ];

    /* ==========================================
       INITIALIZATION
       ========================================== */
    function init() {
      // 1. Load data from LocalStorage
      try {
        const localTasks = localStorage.getItem(STORAGE_KEY_TASKS);
        const localScore = localStorage.getItem(STORAGE_KEY_SCORE);
        
        state.tasks = localTasks ? JSON.parse(localTasks) : [];
        state.score = localScore ? parseInt(localScore, 10) : 0;
      } catch (e) {
        console.error("로컬 스토리지를 로드하는 중 에러가 발생했습니다:", e);
        state.tasks = [];
        state.score = 0;
      }

      // 2. Add event listeners
      elements.inputForm.addEventListener('submit', handleAddTask);
      elements.tabAll.addEventListener('click', () => setFilter('all'));
      elements.tabActive.addEventListener('click', () => setFilter('active'));
      elements.tabCompleted.addEventListener('click', () => setFilter('completed'));
      elements.btnClearCompleted.addEventListener('click', handleClearCompleted);

      // 3. Render initial screen
      updateUI();
    }

    /* ==========================================
       CORE RENDER & STATE SYNC
       ========================================= */
    function saveState() {
      try {
        localStorage.setItem(STORAGE_KEY_TASKS, JSON.stringify(state.tasks));
        localStorage.setItem(STORAGE_KEY_SCORE, state.score.toString());
      } catch (e) {
        console.error("상태 저장 실패:", e);
      }
    }

    function updateUI() {
      saveState();
      renderStats();
      renderTasks();
      updateFilterTabs();
    }

    /* Renders Top Stats Panel & Ranks */
    function renderStats() {
      const completedCount = state.tasks.filter(t => t.complete).length;
      
      // Update values with smooth transitions
      elements.scoreVal.childNodes[0].textContent = state.score + ' ';
      elements.completedVal.childNodes[0].textContent = completedCount + ' ';

      // Calculate Rank
      let currentRank = RANKS[0];
      for (let i = RANKS.length - 1; i >= 0; i--) {
        if (state.score >= RANKS[i].minScore) {
          currentRank = RANKS[i];
          break;
        }
      }

      // Set Rank name & class
      elements.badgeRank.textContent = currentRank.name;
      elements.badgeRank.className = `badge-rank ${currentRank.colorClass || ''}`;

      // Progress bar logic
      if (currentRank.maxScore === Infinity) {
        elements.rankProgressLabel.textContent = '최고 등급 달성! 초월 등급을 유지하세요.';
        elements.rankProgressPercent.textContent = '100%';
        elements.progressBarFill.style.width = '100%';
      } else {
        const range = currentRank.maxScore - currentRank.minScore;
        const progress = state.score - currentRank.minScore;
        const percent = Math.min(Math.max(Math.round((progress / range) * 100), 0), 100);
        
        elements.rankProgressLabel.textContent = `다음 등급(${RANKS[RANKS.indexOf(currentRank) + 1].name})까지`;
        elements.rankProgressPercent.textContent = `${percent}%`;
        elements.progressBarFill.style.width = `${percent}%`;
      }
    }

    /* Renders Task List based on current Filter */
    function renderTasks() {
      elements.taskListContainer.innerHTML = '';
      
      const filteredTasks = state.tasks.filter(task => {
        if (state.filter === 'active') return !task.complete;
        if (state.filter === 'completed') return task.complete;
        return true;
      });

      if (filteredTasks.length === 0) {
        renderEmptyState();
        return;
      }

      filteredTasks.forEach(task => {
        const taskCard = createTaskElement(task);
        elements.taskListContainer.appendChild(taskCard);
      });
    }

    /* Renders Clean Empty State Banner */
    function renderEmptyState() {
      let descText = '계획 중이거나 완료된 학습 과제가 없습니다. 새로운 목표를 등록해 보세요!';
      if (state.filter === 'active') descText = '현재 진행 중인 목표가 없네요! 오늘 완수할 계획을 수립해 보세요.';
      if (state.filter === 'completed') descText = '아직 완료된 학습 목표가 없어요. 차근차근 계획 단계부터 밟아보세요!';

      const emptyDiv = document.createElement('div');
      emptyDiv.className = 'empty-state';
      emptyDiv.innerHTML = `
        <div class="empty-icon">${SVGS.empty}</div>
        <div class="empty-title">목표 목록이 비어있습니다</div>
        <div class="empty-desc">${descText}</div>
      `;
      elements.taskListContainer.appendChild(emptyDiv);
    }

    /* Updates tab counts and styles */
    function updateFilterTabs() {
      const totalCount = state.tasks.length;
      const activeCount = state.tasks.filter(t => !t.complete).length;
      const completedCount = state.tasks.filter(t => t.complete).length;

      elements.badgeAll.textContent = totalCount;
      elements.badgeActive.textContent = activeCount;
      elements.badgeCompleted.textContent = completedCount;

      // Show/Hide Clear completed button
      if (completedCount > 0) {
        elements.btnClearCompleted.style.display = 'flex';
      } else {
        elements.btnClearCompleted.style.display = 'none';
      }
    }

    /* ==========================================
       COMPONENT BUILDER (TASK CARD CARD)
       ========================================== */
    function createTaskElement(task) {
      const card = document.createElement('div');
      card.className = `task-card ${task.complete ? 'state-complete' : ''}`;
      card.id = `task-card-${task.id}`;

      // Build overall HTML
      card.innerHTML = `
        <div class="task-header">
          <div class="task-title-container">
            <span class="task-bullet"></span>
            <span class="task-title">${escapeHTML(task.title)}</span>
          </div>
          <button class="btn-delete" title="목표 삭제" aria-label="삭제">
            ${SVGS.delete}
          </button>
        </div>
        <div class="checklist-flow">
          <button class="step-pill" data-step="plan">
            ${SVGS.check}${SVGS.lock}
            <span>계획</span>
          </button>
          <span class="step-connector c1">➔</span>
          <button class="step-pill" data-step="execute">
            ${SVGS.check}${SVGS.lock}
            <span>실행</span>
          </button>
          <span class="step-connector c2">➔</span>
          <button class="step-pill" data-step="complete">
            ${SVGS.check}${SVGS.lock}
            <span>완료</span>
          </button>
        </div>
      `;

      // Apply states to steps
      updateCardSteps(card, task);

      // Event: Delete Click
      card.querySelector('.btn-delete').addEventListener('click', (e) => {
        e.stopPropagation();
        handleDeleteTask(task.id);
      });

      // Events: Step Buttons Click
      const stepButtons = card.querySelectorAll('.step-pill');
      stepButtons.forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          const step = btn.getAttribute('data-step');
          handleToggleStep(task.id, step, btn);
        });
      });

      return card;
    }

    /* Enforce visual classes based on task state */
    function updateCardSteps(cardElement, task) {
      const btnPlan = cardElement.querySelector('.step-pill[data-step="plan"]');
      const btnExecute = cardElement.querySelector('.step-pill[data-step="execute"]');
      const btnComplete = cardElement.querySelector('.step-pill[data-step="complete"]');

      // Helper to reset and apply classes
      function setStepState(btn, stateClass) {
        btn.className = `step-pill ${stateClass}`;
      }

      // Step 1: Plan
      // Plan is always unlocked, but can be checked/unchecked
      setStepState(btnPlan, task.plan ? 'checked' : 'unlocked');

      // Step 2: Execute
      if (task.plan) {
        setStepState(btnExecute, task.execute ? 'checked' : 'unlocked');
      } else {
        setStepState(btnExecute, 'locked');
      }

      // Step 3: Complete
      if (task.plan && task.execute) {
        setStepState(btnComplete, task.complete ? 'checked' : 'unlocked');
      } else {
        setStepState(btnComplete, 'locked');
      }
    }

    /* ==========================================
       ACTION HANDLERS & STATE MUTATORS
       ========================================= */
    
    /* Add Task */
    function handleAddTask(e) {
      e.preventDefault();
      
      const titleText = elements.taskInput.value.trim();
      if (!titleText) return;

      const newTask = {
        id: Date.now().toString(),
        title: titleText,
        plan: false,
        execute: false,
        complete: false,
        createdAt: new Date().toISOString()
      };

      state.tasks.unshift(newTask);
      elements.taskInput.value = '';
      
      updateUI();
      showToast('새로운 학습 계획이 등록되었습니다! 📝');
    }

    /* Delete Task */
    function handleDeleteTask(taskId) {
      const index = state.tasks.findIndex(t => t.id === taskId);
      if (index === -1) return;

      const task = state.tasks[index];
      const card = document.getElementById(`task-card-${taskId}`);

      // If task was completed, we do NOT decrease score, because it was already earned.
      // But we just notify the user.
      
      if (card) {
        card.classList.add('removing');
        card.addEventListener('transitionend', () => {
          state.tasks.splice(index, 1);
          updateUI();
          showToast('목표를 삭제하였습니다.');
        }, { once: true });
      } else {
        state.tasks.splice(index, 1);
        updateUI();
      }
    }

    /* Sequential Checklist Toggling */
    function handleToggleStep(taskId, step, clickedBtn) {
      const task = state.tasks.find(t => t.id === taskId);
      if (!task) return;

      let scoreDiff = 0;
      let toastMsg = '';

      if (step === 'plan') {
        if (!task.plan) {
          // Check Plan
          task.plan = true;
          toastMsg = '계획을 확인했습니다! 목표를 실행해보세요. 🚀';
        } else {
          // Uncheck Plan. Enforces resetting subsequent steps!
          task.plan = false;
          
          // If unchecking plan, execute and complete must also be unchecked.
          if (task.complete) {
            scoreDiff = -1; // Decrement score if it was completed
          }
          task.execute = false;
          task.complete = false;
          toastMsg = '계획 상태로 초기화되었습니다.';
        }
      } 
      
      else if (step === 'execute') {
        // Enforce ordering: Can only toggle if plan is checked
        if (!task.plan) {
          showToast('먼저 계획(Plan)을 완료해 주세요! 🔒');
          return;
        }

        if (!task.execute) {
          // Check Execute
          task.execute = true;
          toastMsg = '실행 중입니다! 끝까지 힘내세요! 💪';
        } else {
          // Uncheck Execute. Enforces resetting complete!
          task.execute = false;
          if (task.complete) {
            scoreDiff = -1; // Decrement score if it was completed
          }
          task.complete = false;
          toastMsg = '실행이 일시 중지되었습니다.';
        }
      } 
      
      else if (step === 'complete') {
        // Enforce ordering: Can only toggle if execute is checked
        if (!task.plan || !task.execute) {
          showToast('계획 및 실행이 먼저 달성되어야 합니다! 🔒');
          return;
        }

        if (!task.complete) {
          // Check Complete
          task.complete = true;
          scoreDiff = 1;
          toastMsg = '축하합니다! 학습 과제 완료! +1 XP 🌟';
          
          // Trigger Confetti explosion
          triggerConfetti(clickedBtn);
        } else {
          // Uncheck Complete
          task.complete = false;
          scoreDiff = -1;
          toastMsg = '완료가 취소되었습니다. (점수 회수)';
        }
      }

      // Apply score change
      state.score = Math.max(state.score + scoreDiff, 0); // Keep score non-negative
      
      // Sync State & Re-render
      updateUI();

      if (toastMsg) {
        showToast(toastMsg);
      }
    }

    /* Filter Tasks Tabs switching */
    function setFilter(filterType) {
      state.filter = filterType;
      
      // Update UI active states
      document.querySelectorAll('.filter-tab').forEach(tab => {
        tab.classList.remove('active');
      });

      if (filterType === 'all') elements.tabAll.classList.add('active');
      if (filterType === 'active') elements.tabActive.classList.add('active');
      if (filterType === 'completed') elements.tabCompleted.classList.add('active');

      renderTasks();
    }

    /* Remove all completed tasks */
    function handleClearCompleted() {
      // Find completed task IDs
      const completedTasks = state.tasks.filter(t => t.complete);
      if (completedTasks.length === 0) return;

      if (confirm(`완료된 ${completedTasks.length}개의 목표를 삭제하시겠습니까?`)) {
        state.tasks = state.tasks.filter(t => !t.complete);
        updateUI();
        showToast('완료된 목표 목록을 정리했습니다.');
      }
    }

    /* ==========================================
       UTILITIES & MICRO-EFFECTS (CONFETTI, TOAST)
       ========================================= */
    
    /* Escaping user inputs */
    function escapeHTML(str) {
      return str.replace(/[&<>'"]/g, 
        tag => ({
          '&': '&amp;',
          '<': '&lt;',
          '>': '&gt;',
          "'": '&#39;',
          '"': '&quot;'
        }[tag] || tag)
      );
    }

    /* Custom Toast popup */
    function showToast(message) {
      const toast = document.createElement('div');
      toast.className = 'toast';
      toast.textContent = message;
      
      elements.toastContainer.appendChild(toast);
      
      // Remove element after animation completes (2.8s total)
      setTimeout(() => {
        toast.remove();
      }, 2800);
    }

    /* Lightweight Canvas-less Particle Confetti on target element */
    function triggerConfetti(targetElement) {
      const rect = targetElement.getBoundingClientRect();
      const centerX = rect.left + rect.width / 2;
      const centerY = rect.top + rect.height / 2;
      
      const particleCount = 25;
      const colors = ['#3b82f6', '#60a5fa', '#10b981', '#fbbf24', '#ff007f', '#a855f7'];

      for (let i = 0; i < particleCount; i++) {
        const particle = document.createElement('div');
        particle.className = 'particle';
        
        // Random particle styling
        const size = Math.random() * 8 + 4;
        const color = colors[Math.floor(Math.random() * colors.length)];
        
        particle.style.width = `${size}px`;
        particle.style.height = `${size}px`;
        particle.style.backgroundColor = color;
        particle.style.left = `${centerX}px`;
        particle.style.top = `${centerY}px`;

        // Calculate random destination direction
        const angle = Math.random() * Math.PI * 2;
        const velocity = Math.random() * 90 + 40;
        const tx = Math.cos(angle) * velocity;
        const ty = Math.sin(angle) * velocity - (Math.random() * 40 + 20); // slightly pull upward

        particle.style.setProperty('--tx', `${tx}px`);
        particle.style.setProperty('--ty', `${ty}px`);

        document.body.appendChild(particle);

        // Remove particle element after animation runs
        setTimeout(() => {
          particle.remove();
        }, 800);
      }
    }

    // Fire application on window load
    window.addEventListener('DOMContentLoaded', init);

  </script>
