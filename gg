    <section class="filter-section">
      <div class="filter-tabs">
        <button class="filter-tab active" data-filter="all" id="tab-all">
          전체 <span class="tab-badge" id="badge-all">0</span>
        </button>
        <button class="filter-tab" data-filter="active" id="tab-active">
          진행 중 <span class="tab-badge" id="badge-active">0</span>
        </button>
        <button class="filter-tab" data-filter="completed" id="tab-completed">
          완료됨 <span class="tab-badge" id="badge-completed">0</span>
        </button>
